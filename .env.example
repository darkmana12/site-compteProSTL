# Copier vers .env.local et remplir les valeurs (ne jamais committer .env.local)

# Cloudflare R2 — dashboard R2 → Account ID, puis API Tokens → Create API token (lecture sur le bucket)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=site-comptepersostl

# Secret pour l’API GET /api/download (min. 8 caractères). Même valeur dans l’URL ?token=... ou header Authorization: Bearer ...
# En production, remplacer par une vérif. commande payée (Stripe webhook) avant d’appeler getSignedDownloadUrl.
R2_DOWNLOAD_SECRET=

# Stripe (mode test : sk_test_ / pk_test_) — Developers → API keys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Webhook : Developers → Webhooks, ou en local : stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=

# Optionnel : URL publique du site (sinon déduit des en-têtes HTTP au checkout)
# NEXT_PUBLIC_APP_URL=https://votre-domaine.com
